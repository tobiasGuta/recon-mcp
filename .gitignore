# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Virtual environments and local environment files
.venv/
venv/
env/
ENV/
.env
.env.*
!.env.example

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
wheelhouse/

# Local scope configuration and snapshots
config/scope.json
snapshots/
**/snapshots/
*.jsonl

# Generated recon output
output/*
!output/.gitkeep
!output/**/.gitkeep

# Local runtime databases, logs, and scratch files
*.log
*.sqlite
*.sqlite3
*.db
tmp/
temp/

# Editor and OS noise
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
